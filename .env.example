WHATSAPP_MICROSERVICE_URL=http://localhost:3001
WHATSAPP_MICROSERVICE_SECRET=change_me_to_a_long_random_string

# Email Notifications
BOOKING_EMAIL_TO_PATIENT=true
BOOKING_EMAIL_TO_THERAPIST=true

# Chat
