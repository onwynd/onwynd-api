# SMS (Termii)
TERMII_API_KEY=
TERMII_SENDER_ID=Onwynd

# WhatsApp — Meta / Facebook Cloud API (provider = 'meta')
# Get these from Meta Business Manager → WhatsApp → Phone Numbers
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# WhatsApp QR-linked-device microservice (whatsapp-service/)
