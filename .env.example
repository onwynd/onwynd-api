# Transcription
# Options: openai | local_whisper
# Use local_whisper for on-prem Whisper (returns {"text":"..."} JSON)
TRANSCRIBER_DRIVER=local_whisper
STT_URL=https://stt.onwynd.com/asr?output=json
LOCAL_WHISPER_URL=
